# LLM Provider Keys (use at least one)
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=sk-your_key_here
ANTHROPIC_API_KEY=sk-ant-your_key_here
GOOGLE_API_KEY=your_key_here

# Ollama (local, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# === Provider per role ===
# DEFAULT_PROVIDER is the fallback if role-specific ones not set.
# Example: main LLM on Groq (fast, strong), curator/summarizer local (free, unlimited)
DEFAULT_PROVIDER=ollama

# Uncomment to use mixed providers:
# MAIN_PROVIDER=groq
# CURATOR_PROVIDER=ollama
# SUMMARIZER_PROVIDER=ollama

# === Models per role ===
# MAIN_LLM_MODEL=llama-3.3-70b-versatile   # Groq
# CURATOR_MODEL=ollama/qwen2.5:3b           # local
# SUMMARIZER_MODEL=ollama/qwen2.5:3b        # local
