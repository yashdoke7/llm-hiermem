# ----------------------------------------------------------------------------
# API keys (set only those providers you use)
# ----------------------------------------------------------------------------
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ----------------------------------------------------------------------------
# Provider/model routing
# ----------------------------------------------------------------------------
DEFAULT_PROVIDER=ollama
MAIN_PROVIDER=ollama
CURATOR_PROVIDER=ollama
SUMMARIZER_PROVIDER=ollama

MAIN_LLM_MODEL=ollama/qwen2.5:14b
CURATOR_MODEL=ollama/qwen2.5:3b
SUMMARIZER_MODEL=ollama/qwen2.5:3b

# ----------------------------------------------------------------------------
# Ollama runtime
# ----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CONTEXT_SIZE=32768
OLLAMA_KEEP_ALIVE=30m

# ----------------------------------------------------------------------------
# Local persistence and storage behavior
# ----------------------------------------------------------------------------
# Base data root for local HierMem runtime state
HIERMEM_DATA_DIR=.hiermem_data
# Folder for persisted archive state (L0/L1)
HIERMEM_STATE_DIR=.hiermem_data/state
# Chroma DB directory
CHROMA_DB_PATH=.hiermem_data/chroma_data
# Chroma collection name for this app/session space
CHROMA_COLLECTION_NAME=hiermem
# false for normal library usage; true for clean benchmark/reset runs
CLEAR_VECTOR_ON_START=false

# ----------------------------------------------------------------------------
# Context budgets
# ----------------------------------------------------------------------------
TOTAL_CONTEXT_BUDGET=8192
HIERMEM_CONTEXT_BUDGET=8192
RAW_LLM_CONTEXT_BUDGET=8192
RAG_CONTEXT_BUDGET=8192
RAG_SUMMARY_CONTEXT_BUDGET=8192

# 0 = auto (90% of HIERMEM_CONTEXT_BUDGET)
HIERMEM_PASSTHROUGH_THRESHOLD=0

# ----------------------------------------------------------------------------
# Optional runtime tuning
# ----------------------------------------------------------------------------
MAX_RETRIES=5
